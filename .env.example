# Template de variáveis de ambiente
# Copie para .env e preencha os valores reais
# cp .env.example .env

# Gere com:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# True em dev, False em produção
DJANGO_DEBUG=True

# Em produção: ALLOWED_HOSTS=example.com,api.example.com
ALLOWED_HOSTS=

# Email (opcional em dev)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Cache Redis (opcional — só em prod)
REDIS_URL=
